{
  "name": "dubclean",
  "version": "1.0.1",
  "description": "Desktop app untuk blur watermark, burn-in subtitle SRT, dan add/replace audio",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "start:direct": "node_modules/electron/dist/electron.exe .",
    "build:win": "electron-builder --win --publish never",
    "build:linux": "electron-builder --linux"
  },
  "author": "0xHulk",
  "license": "MIT",
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.dubclean.app",
    "productName": "DubClean",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  }
}